<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ciube.glass.coke"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="19"
        android:targetSdkVersion="19" />

    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:label="@string/app_name"
        android:theme="@style/GlassTheme" >

        <!-- Entry point: voice trigger "start a round of golf" -->
        <activity
            android:name="com.ciube.glass.coke.MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@android:drawable/ic_menu_compass"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="com.google.android.glass.action.VOICE_TRIGGER" />
            </intent-filter>

            <meta-data
                android:name="com.google.android.glass.VoiceTrigger"
                android:resource="@xml/voice_trigger" />
        </activity>

        <!-- Immersion activity: scrollable list of golf utilities -->
        <activity
            android:name="com.ciube.glass.coke.GolfMenuActivity"
            android:exported="false"
            android:label="@string/app_name" />
    </application>

</manifest>